# Production environment example.
# Copy this file to .env.local on the server, then fill real values there.
# Do not commit .env.local.

AI_PROVIDER=deepseek

# DeepSeek-compatible settings.
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI-compatible settings.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=your_openai_model_here

# Generic AI override settings. Leave empty if you only use provider-specific settings.
AI_API_KEY=your_ai_api_key_here
AI_BASE_URL=your_ai_base_url_here
AI_MODEL=your_ai_model_here
AI_TIMEOUT_MS=30000

# App access password. Use a strong password in production.
ACCESS_PASSWORD=your_strong_access_password_here
APP_ACCESS_PASSWORD=your_strong_access_password_here

# SQLite database path for production history data.
DATABASE_URL=file:./prod.db

# Keep diagnostics disabled in production.
ENABLE_AI_DIAGNOSTICS=false
