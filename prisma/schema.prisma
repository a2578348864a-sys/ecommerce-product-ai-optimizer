generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ListingCopyHistory {
  id               String   @id @default(cuid())
  productId        String?
  productName      String
  title            String
  bulletPoints     String
  description      String
  shortDescription String
  keywords         String
  longTailKeywords String
  faq              String
  packingList      String
  afterSales       String
  notes            String
  sourceInput      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([createdAt])
  @@index([productName])
}
