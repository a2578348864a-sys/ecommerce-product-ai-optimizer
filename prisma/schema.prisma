generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ListingCopyHistory {
  id               String   @id @default(cuid())
  productId        String?
  productName      String
  title            String
  bulletPoints     String
  description      String
  shortDescription String
  keywords         String
  longTailKeywords String
  faq              String
  packingList      String
  afterSales       String
  notes            String
  sourceInput      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([createdAt])
  @@index([productName])
}

model ViralAnalysisRecord {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  type           String   @default("viral")
  decisionStatus String   @default("pending")
  title          String?
  platform       String
  productUrl     String?
  materialText   String
  source         String
  score          Int
  level          String
  oneLineSummary String
  resultJson     String

  @@index([type, createdAt])
  @@index([decisionStatus, createdAt])
  @@index([source])
  @@index([platform])
}
